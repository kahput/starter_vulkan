#version 450
#pragma shader_stage(fragment)

layout(set = 0, binding = 0) uniform sampler2D u_base_layer;
layout(set = 0, binding = 1) uniform sampler2D u_top_layer;

layout(location = 0) in vec2 in_uv;
layout(location = 0) out vec4 out_color;

void main() {
    vec4 base = texture(u_base_layer, vec2(in_uv));
    vec4 top = texture(u_top_layer, vec2(in_uv));
    out_color = vec4(mix(base.rgb, top.rgb, top.a), 1.0f);
}
